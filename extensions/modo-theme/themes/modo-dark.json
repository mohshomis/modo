  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#52525b", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#34d399" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#f59e0b" } },
    { "scope": "constant.language", "settings": { "foreground": "#f87171" } },
    { "scope": "keyword", "settings": { "foreground": "#a78bfa" } },
    { "scope": "keyword.control", "settings": { "foreground": "#c084fc" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#14b8a6" } },
    { "scope": "storage.type", "settings": { "foreground": "#60a5fa" } },
    { "scope": "storage.modifier", "settings": { "foreground": "#a78bfa" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#60a5fa" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#fbbf24" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#2dd4bf" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#f87171" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#fbbf24" } },
    { "scope": "support.function", "settings": { "foreground": "#14b8a6" } },
    { "scope": "support.class", "settings": { "foreground": "#2dd4bf" } },
    { "scope": "support.type", "settings": { "foreground": "#2dd4bf" } },
    { "scope": "variable", "settings": { "foreground": "#d4d4d8" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#f59e0b" } },
    { "scope": "variable.other.property", "settings": { "foreground": "#d4d4d8" } },
    { "scope": "punctuation", "settings": { "foreground": "#71717a" } },
    { "scope": "meta.import", "settings": { "foreground": "#a78bfa" } },
    { "scope": "markup.heading", "settings": { "foreground": "#60a5fa", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#14b8a6" } }
  ]
